---
import ModeToggle from './ModeToggle.astro';
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href={base}>
      <span class="brand__mark" aria-hidden="true">▣</span>
      <span class="brand__name">didi.sh <span class="brand__sub">id</span></span>
      <span class="brand__short" aria-hidden="true">ID·SH</span>
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      <a href={`${base}#services`}>Services</a>
      <a href={`${base}#credential`}>The ID</a>
      <a href="https://lossless-group.github.io/id-didi-sh/changelog/">Build log</a>
      <a
        href="https://github.com/lossless-group/id-didi-sh"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
    </nav>
    <div class="site-header__actions">
      <ModeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 64px;
  }

  .site-header__actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--color-text);
    font-family: var(--font__sans);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: -0.005em;
  }
  .site-header__brand:hover { text-decoration: none; }

  .brand__mark {
    color: var(--color-accent);
    font-size: 1.4rem;
    line-height: 1;
  }
  .brand__sub {
    font-family: var(--font__mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-dim);
  }
  .brand__short {
    display: none;
    font-family: var(--font__mono);
    font-size: 0.78rem;
    color: var(--color-text-dim);
    letter-spacing: 0.12em;
  }

  @media (max-width: 720px) {
    .brand__name { display: none; }
    .brand__short { display: inline; }
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-left: auto;
    font-size: 0.9rem;
  }
  .site-header__nav a {
    color: var(--color-text-soft);
  }
  .site-header__nav a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 860px) {
    .site-header__nav { gap: var(--space-3); font-size: 0.84rem; }
    .site-header__nav a:nth-child(n+4) { display: none; }
  }
</style>
